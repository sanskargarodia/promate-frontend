# ─── Connect to the deployed AgentCore agent ────────────────────────────────
# The browser calls same-origin /api/chat (app/api/chat/route.ts), which signs an
# InvokeAgentRuntime call to AgentCore. These are SERVER-side vars (no
# NEXT_PUBLIC_ prefix → never shipped to the browser).

AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:211125453575:runtime/app_agent_core_entrypoint-PGre0T4zQL
AWS_REGION=us-east-1

# AWS credentials for the proxy — a scoped IAM user that can ONLY call
# bedrock-agentcore:InvokeAgentRuntime on the runtime above.
# On Vercel: set these in Project Settings → Environment Variables (never commit real values).
# For local `next dev`: put them in .env.local (gitignored).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
